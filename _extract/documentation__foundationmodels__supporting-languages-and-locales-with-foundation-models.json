{"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Generate content in the language people prefer when they interact with your app."}],"seeAlsoSections":[{"anchor":"Language-and-locales","identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/supportsLocale(_:)","doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/GenerationError/unsupportedLanguageOrLocale(_:)"],"generated":true,"title":"Language and locales"}],"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.foundationmodels/documentation/FoundationModels"]]},"metadata":{"roleHeading":"Article","role":"article","title":"Supporting languages and locales with Foundation Models","modules":[{"name":"Foundation Models"}]},"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.foundationmodels/documentation/FoundationModels/supporting-languages-and-locales-with-foundation-models"},"sections":[],"variants":[{"paths":["/documentation/foundationmodels/supporting-languages-and-locales-with-foundation-models"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"The on-device system language model is multilingual, which means the same model","type":"text"},{"type":"text","text":" "},{"text":"understands and generates text in any language that Apple Intelligence supports.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The model supports using different languages for prompts, instructions, and the"},{"text":" ","type":"text"},{"type":"text","text":"output that the model produces."}]},{"inlineContent":[{"type":"text","text":"When you enhance your app with multilingual support, generate content in the"},{"text":" ","type":"text"},{"type":"text","text":"language people prefer to use when they interact with your app by:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Prompting the model with the language you prefer.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Including the target language for your app in the instructions you provide the model."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Determining the language or languages a person wants to use when they interact with your app.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Gracefully handling languages that Apple Intelligence doesn’t support.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"For more information about the languages and locales that Apple Intelligence","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"supports, see the “Supported languages” section in "},{"identifier":"https://support.apple.com/en-us/121115","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"text":"Prompt the model in the language you prefer","level":2,"type":"heading","anchor":"Prompt-the-model-in-the-language-you-prefer"},{"inlineContent":[{"type":"text","text":"Write your app’s built-in prompts in the language with which you normally write"},{"text":" ","type":"text"},{"text":"code, if Apple Intelligence supports that language. Translate your prompts into a","type":"text"},{"text":" ","type":"text"},{"text":"supported language if your preferred language isn’t supported. In the code below,","type":"text"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"all","type":"text"}]},{"text":" inputs need to be in supported language for the model to understand, including","type":"text"},{"type":"text","text":" "},{"text":"all ","type":"text"},{"code":"Generable","type":"codeVoice"},{"type":"text","text":" types and descriptions:"}],"type":"paragraph"},{"syntax":"swift","code":["@Generable(description: \"Basic profile information about a cat\")","struct CatProfile {","    var name: String","","    @Guide(description: \"The age of the cat\", .range(0...20))","    var age: Int","","    @Guide(description: \"One sentence about this cat's personality\")","    var profile: String","}","","#Playground {","    let response = try await LanguageModelSession().respond(","        to: \"Generate a rescue cat\",","        generating: CatProfile.self","    )","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Because the framework treats "},{"type":"codeVoice","code":"Generable"},{"type":"text","text":" types as model inputs, the names of"},{"text":" ","type":"text"},{"type":"text","text":"properties like "},{"code":"age","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"profile","type":"codeVoice"},{"text":" are just as important as the ","type":"text"},{"code":"@Guide","type":"codeVoice"},{"text":"","type":"text"},{"text":" ","type":"text"},{"text":"descriptions for helping the model understand your request.","type":"text"}],"type":"paragraph"},{"text":"Check a person’s language settings for your app","level":2,"anchor":"Check-a-persons-language-settings-for-your-app","type":"heading"},{"inlineContent":[{"text":"People can use the Settings app on their device to configure the language they","type":"text"},{"type":"text","text":" "},{"type":"text","text":"prefer to use on a per-app basis, which might differ from their default language."},{"text":" ","type":"text"},{"text":"If your app supports a language that Apple Intelligence doesn’t, you need to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"verify that the current language setting of your app is supported before you call"},{"text":" ","type":"text"},{"type":"text","text":"the model. Keep in mind that language support improves over time in newer model"},{"text":" ","type":"text"},{"text":"and OS versions. Thus, someone using your app with an older OS may not have the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"latest language support."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before you call the model, run "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/supportsLocale(_:)","type":"reference","isActive":true},{"type":"text","text":" to verify"},{"type":"text","text":" "},{"type":"text","text":"the support for a locale. By default, the method uses"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.documentation/documentation/Foundation/Locale/current"},{"type":"text","text":", which"},{"type":"text","text":" "},{"text":"takes into account a person’s current language and app-specific settings. This","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"method returns true if the model supports this locale, or if this locale is"},{"type":"text","text":" "},{"type":"text","text":"considered similar enough to a supported locale, such as "},{"code":"en-AU","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"en-NZ"},{"text":":","type":"text"}]},{"type":"codeListing","code":["if SystemLanguageModel.default.supportsLocale() {","    // Language is supported.","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"For advanced use cases where you need full language support details, use","type":"text"},{"text":" ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/supportedLanguages","type":"reference","isActive":true},{"text":" to retrieve a list of languages supported","type":"text"},{"text":" ","type":"text"},{"text":"by the on-device model.","type":"text"}]},{"text":"Handle an unsupported language or locale errors","anchor":"Handle-an-unsupported-language-or-locale-errors","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"When you call ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/respond(to:options:)"},{"type":"text","text":" on a"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession","type":"reference"},{"type":"text","text":", the Foundation Models framework checks the language or"},{"type":"text","text":" "},{"type":"text","text":"languages of the input prompt text, and whether your prompt asks the model to"},{"text":" ","type":"text"},{"type":"text","text":"respond in any specific language or languages. If the model detects a language"},{"text":" ","type":"text"},{"type":"text","text":"it doesn’t support, the session throws"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/GenerationError/unsupportedLanguageOrLocale(_:)","type":"reference"},{"text":". Handle","type":"text"},{"text":" ","type":"text"},{"text":"the error by communicating to the person using your app that a language in their","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"request is unsupported."}]},{"inlineContent":[{"type":"text","text":"If your app supports languages or locales that Apple Intelligence doesn’t, help"},{"type":"text","text":" "},{"text":"people that use your app by:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Explaining that their language isn’t supported by Apple Intelligence in your app.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Disabling your Foundation Models framework feature."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Providing an alternative app experience, if possible."}]}]}],"type":"unorderedList"},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Guardrails for model input and output safety are only for"},{"type":"text","text":" "},{"type":"text","text":"supported languages and locales. If a prompt contains sensitive content in an"},{"text":" ","type":"text"},{"text":"unsupported language, which typically is a short phrase mixed-in with text in a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"supported language, it might not throw a"},{"text":" ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/GenerationError/unsupportedLanguageOrLocale(_:)","isActive":true,"type":"reference"},{"text":" error.","type":"text"},{"text":" ","type":"text"},{"text":"If unsupported-language detection fails, the guardrails may also fail to flag","type":"text"},{"text":" ","type":"text"},{"text":"that short, unsupported content. For more on guardrails, see","type":"text"},{"type":"text","text":" "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/improving-the-safety-of-generative-model-output","isActive":true,"type":"reference"},{"type":"text","text":"."}]}]},{"anchor":"Use-Instructions-to-set-the-locale-and-language","text":"Use Instructions to set the locale and language","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"For locales other than United States English, you can improve response quality by","type":"text"},{"type":"text","text":" "},{"text":"telling the model which locale to use by detailing a set of ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Instructions","isActive":true,"type":"reference"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Start with the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"exact"}]},{"text":" phrase in English. This special phrase comes from the","type":"text"},{"type":"text","text":" "},{"text":"model’s training, and reduces the possibility of hallucinations in multilingual","type":"text"},{"text":" ","type":"text"},{"text":"situations:","type":"text"}]},{"code":["func localeInstructions(for locale: Locale = Locale.current) -> String {","    if Locale.Language(identifier: \"en_US\").isEquivalent(to: locale.language) {","        // Skip the locale phrase for U.S. English.","        return \"\" ","    } else {","        // Specify the person's locale with the exact phrase format.","        return \"The person's locale is \\(locale.identifier).\"","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After you set the locale in "},{"type":"codeVoice","code":"Instructions"},{"text":", you may need to explicitly set the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"model output language. By default, the model responds in the language or languages"},{"type":"text","text":" "},{"type":"text","text":"of its inputs. If your app supports multiple languages, prompts that you write"},{"type":"text","text":" "},{"text":"and inputs from people using your app might be in different languages. For example,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if you write your built-in prompts in Spanish, but someone using your app writes"},{"type":"text","text":" "},{"type":"text","text":"inputs in Dutch, the model may respond in either or both languages."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"Instructions"},{"text":" to explicity tell the model which language or languages","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with witch it needs to respond. You can phrase this request in different ways,"},{"text":" ","type":"text"},{"text":"for example: “You MUST respond in Italian” or “You MUST respond in Italian and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be mindful of Italian spelling, vocabulary, entities, and other cultural contexts"},{"text":" ","type":"text"},{"type":"text","text":"of Italy.” These instructions can be in the language you prefer."}]},{"syntax":"swift","code":["let session = LanguageModelSession(","    instructions: \"You MUST respond in U.S. English.\"",")","let prompt = // A prompt that contains Spanish and Italian.","let response = try await session.respond(to: prompt)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, thoroughly test your instructions to ensure the model is responding in"},{"text":" ","type":"text"},{"type":"text","text":"the way you expect. If the model isn’t following your instructions, try"},{"type":"text","text":" "},{"type":"text","text":"capitalized words like “MUST” or “ALWAYS” to strengthen your instructions."}]}]}],"references":{"doc://com.apple.documentation/documentation/Foundation/Locale/current":{"url":"/documentation/Foundation/Locale/current","type":"topic","title":"current","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"current","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Locale","preciseIdentifier":"s:10Foundation6LocaleV","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"A locale representing the user’s region settings at the time the property is read."}],"identifier":"doc://com.apple.documentation/documentation/Foundation/Locale/current","role":"symbol","kind":"symbol"},"doc://com.apple.foundationmodels/documentation/FoundationModels":{"url":"/documentation/foundationmodels","abstract":[{"type":"text","text":"Perform tasks with the on-device model that specializes in language understanding, structured output, and tool calling."}],"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels","images":[{"identifier":"foundation-models-framework-landing-PageImage-card.png","type":"card"}],"title":"Foundation Models","type":"topic","role":"collection","kind":"symbol"},"https://support.apple.com/en-us/121115":{"type":"link","identifier":"https://support.apple.com/en-us/121115","url":"https://support.apple.com/en-us/121115","titleInlineContent":[{"text":"How to get Apple Intelligence","type":"text"}],"title":"How to get Apple Intelligence"},"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/supportedLanguages":{"title":"supportedLanguages","role":"symbol","kind":"symbol","abstract":[{"text":"Languages that the model supports.","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"supportedLanguages","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Set","preciseIdentifier":"s:Sh","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:10Foundation6LocaleV","kind":"typeIdentifier","text":"Locale"},{"text":".","kind":"text"},{"text":"Language","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation6LocaleV8LanguageV"},{"text":">","kind":"text"}],"type":"topic","url":"/documentation/foundationmodels/systemlanguagemodel/supportedlanguages","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/supportedLanguages"},"foundation-models-framework-landing-PageImage-card.png":{"type":"image","alt":"An illustration that represents a foundation model.","variants":[{"traits":["2x","light"],"url":"https://docs-assets.developer.apple.com/published/274bdf69903b6dd606f05b29f5e08f04/foundation-models-framework-landing-PageImage-card%402x.png"},{"url":"https://docs-assets.developer.apple.com/published/0fc8245c5e8046f5efab6bfe0e1be692/foundation-models-framework-landing-PageImage-card~dark%402x.png","traits":["2x","dark"]}],"identifier":"foundation-models-framework-landing-PageImage-card.png"},"doc://com.apple.foundationmodels/documentation/FoundationModels/improving-the-safety-of-generative-model-output":{"images":[{"identifier":"impr