{"identifier":{"interfaceLanguage":"swift","url":"doc://com.apple.foundationmodels/documentation/FoundationModels/analyzing-the-runtime-performance-of-your-foundation-models-app"},"seeAlsoSections":[{"identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/prompting-an-on-device-foundation-model","doc://com.apple.foundationmodels/documentation/FoundationModels/updating-prompts-for-new-model-versions","doc://com.apple.foundationmodels/documentation/FoundationModels/evaluating-prompts-to-measure-performance-and-improve-model-responses","doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession","doc://com.apple.foundationmodels/documentation/FoundationModels/Instructions","doc://com.apple.foundationmodels/documentation/FoundationModels/Prompt","doc://com.apple.foundationmodels/documentation/FoundationModels/Transcript","doc://com.apple.foundationmodels/documentation/FoundationModels/GenerationOptions"],"generated":true,"title":"Prompting","anchor":"Prompting"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["/documentation/foundationmodels/analyzing-the-runtime-performance-of-your-foundation-models-app"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Optimize token consumption and improve response times by profiling your app’s model usage with Instruments.","type":"text"}],"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.foundationmodels/documentation/FoundationModels"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use Instruments to analyze the runtime performance, resource usage, and behavior","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of your app. Instruments provides several tools to help you understand how"},{"type":"text","text":" "},{"text":"responsive your app is and what kind of power impact it has on the system, as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"well as diagnose hitches and more."}]},{"inlineContent":[{"type":"text","text":"The Foundation Models instrument provides details about the interactions your app"},{"type":"text","text":" "},{"type":"text","text":"has with the on-device model, so you can get insight into:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When the system loads model assets","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"How long it takes to start receiving a response from the model","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"What the token usage is across individual sessions","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Where the model invokes any custom tools your app provides","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The Foundation Models instrument helps you identify exactly where your app spends","type":"text"},{"text":" ","type":"text"},{"text":"time and uses tokens. By analyzing your app’s model usage patterns, you can","type":"text"},{"text":" ","type":"text"},{"text":"identify bottlenecks and apply targeted optimizations to improve responsiveness","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and runtime performance."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use additional instruments — alongside the Foundation Models instrument — to"},{"text":" ","type":"text"},{"text":"understand the impact your model interactions have on thermal state, power, and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"other system resources."}]},{"level":2,"text":"Launch and configure Instruments for recording","anchor":"Launch-and-configure-Instruments-for-recording","type":"heading"},{"inlineContent":[{"text":"Start by opening Instruments from your Xcode project:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"From the Xcode Product menu, choose Profile.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"In the Template Selection window, select the Blank template and click Choose."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Click the “+ Instrument” button in the toolbar to add an instrument.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Search for “Foundation Models” and drag the instrument into your document."}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"type":"image","identifier":"analyzing-the-runtime-performance-of-your-foundation-models-app-template"}],"type":"paragraph"},{"inlineContent":[{"text":"Before you begin recording a session, consider adding additional instruments that","type":"text"},{"text":" ","type":"text"},{"text":"can help you understand the impact your app has on system resources, like Time Profiler,","type":"text"},{"text":" ","type":"text"},{"text":"CPU Profiler, and Power Profiler:","type":"text"}],"type":"paragraph"},{"type":"termList","items":[{"term":{"inlineContent":[{"text":"Time Profiler","type":"text"}]},"definition":{"content":[{"type":"paragraph","inlineContent":[{"text":"Performs time-based sampling to identify where an app is consuming the most processing time.","type":"text"}]}]}},{"definition":{"content":[{"type":"paragraph","inlineContent":[{"text":"Performs fast, low-overhead measurement of CPU time.","type":"text"}]}]},"term":{"inlineContent":[{"type":"text","text":"CPU Profiler"}]}},{"term":{"inlineContent":[{"type":"text","text":"Power Profiler"}]},"definition":{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Performs analysis on the energy consumption across different subsystems."}]}]}}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Some instruments, like Power Profiler, aren’t available to use with","type":"text"},{"type":"text","text":" "},{"text":"Simulator.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"inlineContent":[{"text":"After you configure your template for analyzing your Foundation Models usage,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"choose File > Save As Template, to make it easier to reuse the same configuration"},{"type":"text","text":" "},{"text":"when launching Instruments.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Record-app-interactions-to-gather-data","text":"Record app interactions to gather data"},{"type":"paragraph","inlineContent":[{"text":"Before reviewing the performance of your app, first check that your development","type":"text"},{"type":"text","text":" "},{"type":"text","text":"device isn’t under thermal pressure or busy with other work. This helps you ensure"},{"type":"text","text":" "},{"type":"text","text":"that the device is in a good performance state, which can influence your analysis."},{"text":" ","type":"text"},{"text":"When you record a run, use your app as normal and focus on interactions that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"perform requests to the model. Begin gathering data by clicking the Record Trace"},{"text":" ","type":"text"},{"type":"text","text":"button on the top left or by choosing File > Record Trace:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"analyzing-the-runtime-performance-of-your-foundation-models-app-record"}]},{"inlineContent":[{"type":"text","text":"After you perform actions that generate model responses, wait for the responses"},{"type":"text","text":" "},{"text":"to complete, then click Stop to end recording.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"Get to know the instrument","anchor":"Get-to-know-the-instrument"},{"inlineContent":[{"type":"text","text":"The primary timeline consists of events that the instrument measures. The width of"},{"text":" ","type":"text"},{"type":"text","text":"each component on the timeline indicates latency. The Foundation Models track"},{"type":"text","text":" "},{"type":"text","text":"appears in your timeline, with several graphs that provide insight into your"},{"text":" ","type":"text"},{"text":"session and assets:","type":"text"}],"type":"paragraph"},{"items":[{"term":{"inlineContent":[{"type":"text","text":"Asset Loading"}]},"definition":{"content":[{"inlineContent":[{"type":"text","text":"The time the system needs to load model data from storage before fulfilling a request."}],"type":"paragraph"}]}},{"definition":{"content":[{"inlineContent":[{"type":"text","text":"The start and end points that reflect the time it takes to perform on overall request."}],"type":"paragraph"}]},"term":{"inlineContent":[{"type":"text","text":"Response"}]}},{"term":{"inlineContent":[{"type":"text","text":"Inference"}]},"definition":{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The time the system takes to prepare the generation schema (shown as Prepare Vocabulary), process the input prompt, and compute the output."}]}]}},{"term":{"inlineContent":[{"type":"text","text":"Tool Calling"}]},"definition":{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The time a tool call occurs and the length of time it takes to perform work."}]}]}}],"type":"termList"},{"inlineContent":[{"type":"text","text":"The following image shows the Foundation Models instrument after recording a"},{"text":" ","type":"text"},{"text":"trace:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"analyzing-the-runtime-performance-of-your-foundation-models-app-record-analysis"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To review what is happening at a more granular level, press Command-Plus Sign to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"zoom in, or Command-Minus Sign to zoom out of the timeline:"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"analyzing-the-runtime-performance-of-your-foundation-models-app-timeline"}]},{"text":"Understand token usage","level":2,"type":"heading","anchor":"Understand-token-usage"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you prompt a language model, the model breaks down the input text into little"},{"type":"text","text":" "},{"type":"text","text":"fragments called tokens. Each token is typically a word or a piece of a word. The"},{"type":"text","text":" "},{"type":"text","text":"token count includes instructions, prompts, and outputs for a session instance."},{"type":"text","text":" "},{"type":"text","text":"If your session processes a large number of tokens that exceed the context window,"},{"type":"text","text":" "},{"text":"the framework throws the error","type":"text"},{"type":"text","text":" "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/GenerationError/exceededContextWindowSize(_:)","type":"reference","isActive":true},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"For more information on managing the context window size, see","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc://com.apple.documentation/documentation/Technotes/tn3193-managing-the-on-device-foundation-model-s-context-window","type":"reference"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"More output tokens generally require more processing time. Additionally, processing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"time depends on the task you perform. For example, summarizing a document requires"},{"text":" ","type":"text"},{"text":"much less processing time than writing a new article, because it’s mostly a reading","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"task for the model."}]},{"type":"paragraph","inlineContent":[{"text":"The cost of text varies between characters of symbols versus discrete words. For","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example, the word “Sourdough” might be one token, but a phone number like"},{"text":" ","type":"text"},{"type":"text","text":"+1-(408)-555-0123 might use over ten tokens because of the characters and symbols."}]},{"inlineContent":[{"text":"High token counts affect both initial processing time and memory usage. The","type":"text"},{"text":" ","type":"text"},{"text":"Inference detail area shows token metrics for each session. Token counts above","type":"text"},{"text":" ","type":"text"},{"text":"1000 may slow down response generation, especially on older devices. When you","type":"text"},{"text":" ","type":"text"},{"text":"are testing runtime performance, compare token counts across different app","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"interactions to identify which prompts consume the most tokens."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To compare token counts:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Click the Foundation Models instrument."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Select View > Detail Area > Inference.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"The following image shows the details about a single session, including a"},{"text":" ","type":"text"},{"text":"breakdown of where the session spent time:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"identifier":"analyzing-the-runtime-performance-of-your-foundation-models-app-inference","type":"image"}]},{"inlineContent":[{"type":"text","text":"The Inference detail area reveals a breakdown of the session calls during the"},{"type":"text","text":" "},{"text":"recorded trace. It also includes:","type":"text"}],"type":"paragraph"},{"type":"termList","items":[{"term":{"inlineContent":[{"text":"Count","type":"text"}]},"definition":{"content":[{"inlineContent":[{"type":"text","text":"The number of events that occur."}],"type":"paragraph"}]}},{"term":{"inlineContent":[{"type":"text","text":"Duration"}]},"definition":{"content":[{"inlineContent":[{"type":"text","text":"The length of processing time for the session."}],"type":"paragraph"}]}},{"definition":{"content":[{"inlineContent":[{"text":"An estimate of the required tokens for the prompt, instructions, tools, and so on.","type":"text"}],"type":"paragraph"}]},"term":{"inlineContent":[{"type":"text","text":"Max Input Token Count"}]}},{"term":{"inlineContent":[{"text":"Max Output Token Count","type":"text"}]},"definition":{"content":[{"inlineContent":[{"type":"text","text":"An estimate of the tokens the model uses for a response."}],"type":"paragraph"}]}}]},{"inlineContent":[{"type":"text","text":"For each request, Instruments provides additional details:"}],"type":"paragraph"},{"items":[{"term":{"inlineContent":[{"type":"text","text":"Prompt Processing"}]},"definition":{"content":[{"inlineContent":[{"text":"Measures how long it takes to prepare the request.","type":"text"}],"type":"paragraph"}]}},{"definition":{"content":[{"type":"paragraph","inlineContent":[{"text":"Measures how quickly the model begins generating output. A lower first token latency improves perceived responsiveness.","type":"text"}]}]},"term":{"inlineContent":[{"type":"text","text":"First Token Inference"}]}},{"definition":{"content":[{"type":"paragraph","inlineContent":[{"text":"Measures reasoning and verification processing time. A higher latency indicates where the model is spending time “thinking.”","type":"text"}]}]},"term":{"inlineContent":[{"text":"Extended Inference","type":"text"}]}}],"type":"termList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, the entire timeline is in a selected state. If you want to focus on"},{"text":" ","type":"text"},{"type":"text","text":"a specific time frame to understand more about the performance at a specific point"},{"type":"text","text":" "},{"type":"text","text":"in time, click and drag inside the timeline to select the range you want to analyze,"},{"text":" ","type":"text"},{"text":"or press Command-Plus Sign to zoom in and Command-Minus Sign to zoom out.","type":"text"}]},{"level":2,"type":"heading","anchor":"Optimize-model-loading-with-prewarming","text":"Optimize model loading with prewarming"},{"type":"paragraph","inlineContent":[{"text":"Asset-loading delays appear as gaps between the start of a request and the","type":"text"},{"text":" ","type":"text"},{"text":"first token generation. A delay of several hundred milliseconds before tokens","type":"text"},{"type":"text","text":" "},{"text":"start appearing means that your app loads the model after a person makes a request.","type":"text"},{"type":"text","text":" "},{"text":"If you know that your app needs to make a call to the model soon, use the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/prewarm(promptPrefix:)","isActive":true},{"text":" method to load the model","type":"text"},{"text":" ","type":"text"},{"text":"before you need to call it. Preload the model when you have at least one second","type":"text"},{"type":"text","text":" "},{"text":"before calling a respond method. This technique moves loading time away from the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"critical response path to improve the responsiveness of your app."}]},{"type":"codeListing","code":["// Create a session.","var session = LanguageModelSession()","","// Prewarm the session when a person navigates to a screen that uses the session.","session.prewarm()"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"A prompt prefix helps the model prepare for similar requests, reducing the","type":"text"},{"type":"text","text":" "},{"text":"time to first token. When you know the type of requests a person is about to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"make, improve performance by providing a prefix that matches your app’s common"},{"type":"text","text":" "},{"text":"prompt patterns. For example, if your app generates itineraries, prewarm the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"model with the prefix you expect to use for each request:"}]},{"code":["// Prewarm with context about the likely request.","session.prewarm(promptPrefix: \"Generate a travel itinerary for\")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"After implementing prewarming, profile your app again to verify that asset"},{"type":"text","text":" "},{"type":"text","text":"loading happens before the request is made — eliminating delays in the critical"},{"type":"text","text":" "},{"type":"text","text":"path."}],"type":"paragraph"},{"level":2,"text":"Reduce token consumption","anchor":"Reduce-token-consumption","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A lower token count improves performance and helps you stay within context limits."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"includeSchemaInPrompt"},{"type":"text","text":" parameter in"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/streamResponse(generating:includeSchemaInPrompt:options:prompt:)"},{"text":"","type":"text"},{"type":"text","text":" "},{"text":"tells the framework to include information about ","type":"text"},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable","isActive":true},{"text":" types in your","type":"text"},{"type":"text","text":" "},{"text":"prompts before processing the request. Doing so improves the output quality, but","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requires that the model consumes more input tokens. If you already made a"},{"type":"text","text":" "},{"type":"text","text":"similar request or provided examples in your system instructions, you can exclude"},{"text":" ","type":"text"},{"type":"text","text":"the schema in subsequent requests. Excluding the schema removes redundant schema"},{"text":" ","type":"text"},{"type":"text","text":"information and can save hundreds of tokens per request. To further optimize"},{"text":" ","type":"text"},{"type":"text","text":"token usage, consider whether you need nested "},{"isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable","type":"reference"},{"text":" types in a parent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"type. More context is necessary to handle nested "},{"isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable","type":"reference"},{"type":"text","text":" schema details."}]},{"inlineContent":[{"type":"text","text":"When you no longer need the schema data for your session, set "},{"code":"includeSchemaInPrompt","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to "},{"code":"false","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let response = try await session.streamResponse(","    prompt: prompt,","    generable: MyCustomItinerary.self,","    options: .init(includeSchemaInPrompt: false)",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After you make this change, the Inference section of the Foundation Models"},{"type":"text","text":" "},{"type":"text","text":"instrument displays lower maximum token counts, which translates to faster initial"},{"type":"text","text":" "},{"type":"text","text":"processing. The following screenshot shows the input token count — with"},{"type":"text","text":" "},{"type":"codeVoice","code":"includeSchemaInPrompt"},{"text":" set to ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" — after running three generation"},{"text":" ","type":"text"},{"text":"requests:","type":"text"}]},{"type":"paragraph","inlineContent":[{"identifier":"analyzing-the-runtime-performance-of-your-foundation-models-app-schema-1","type":"image"}]},{"type":"paragraph","inlineContent":[{"text":"The following image shows similar requests, with ","type":"text"},{"type":"codeVoice","code":"includeSchemaInPrompt"},{"type":"text","text":" set"},{"type":"text","text":" "},{"text":"to ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":":"}]},{"inlineContent":[{"type":"image","identifier":"analyzing-the-runtime-performance-of-your-foundation-models-app-schema-2"}],"type":"paragraph"},{"type":"heading","anchor":"Verify-your-optimizations","level":2,"text":"Verify your optimizations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you perform runtime optimization updates in your code, profile your app each"},{"text":" ","type":"text"},{"text":"time to confirm that the changes improve performance. Compare the new timeline with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"your previous recordings, and rename each recording from the sidebar based on"},{"type":"text","text":" "},{"text":"what changed between runs, to help indicate what the run involved.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Successful prewarming moves asset loading earlier in the timeline and before an"},{"type":"text","text":" "},{"type":"text","text":"app makes a request to the model. This reduces the amount of time a session takes"},{"text":" ","type":"text"},{"text":"to start generating a response to the request and shortens the time an app waits","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to perform additional requests or UI updates. The following image shows a request"},{"type":"text","text":" "},{"text":"being made to the model after an app calls ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/prewarm(promptPrefix:)"},{"type":"text","text":":"}]},{"type":"paragraph","inlineContent":[{"identifier":"analyzing-the-runtime-performance-of-your-foundation-models-app-verify-changes","type":"image"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you evaluate your app, look for these improvements in each recording:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Asset loading happens before the app makes the request."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The first tokens appear immediately after the session starts processing the request."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The Inference detail area shows lower token counts.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The overall session and tool-calling response times meet the intended user experience.","type":"text"}]}]}]}]}],"kind":"article","metadata":{"role":"article","modules":[{"name":"Foundation Models"}],"title":"Analyzing the runtime performance of your Foundation Models app","roleHeading":"Article"},"references":{"evaluating-your-apps-prompts-PageImage-card.png":{"identifier":"evaluating-your-apps-prompts-PageImage-card.png","type":"image","alt":"An abstract illustration with a magnifying glass in the center with several ovals representing prompts being evaluated.","variants":[{"url":"https://docs-assets.developer.apple.com/published/0ad5408e2642641ece9c23cbde0aa1de/evaluating-your-apps-prompts-PageImage-card%402x.png","traits":["2x","light"]},{"traits":["2x","dark"],"url":"https://docs-assets.de