{"abstract":[{"text":"Build robust apps with guided generation and tool calling by adopting the Foundation Models framework.","type":"text"}],"seeAlsoSections":[{"generated":true,"title":"Essentials","anchor":"Essentials","identifiers":["doc://com.apple.documentation/documentation/Updates/FoundationModels","doc://com.apple.foundationmodels/documentation/FoundationModels/generating-content-and-performing-tasks-with-foundation-models","doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"This sample project shows how to integrate generative AI capabilities into an app using the Foundation Models framework. The sample app showcases intelligent trip planning features that help people discover landmarks and generate personalized itineraries."}],"type":"paragraph"},{"inlineContent":[{"text":"The app creates an interactive experience where people can:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Browse curated landmarks with rich visual content"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Generate trip itineraries tailored to a chosen landmark","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Discover points of interest using a custom tool"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Experience real-time content generation with streaming responses"}],"type":"paragraph"}]}],"type":"unorderedList"},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"text":"This sample code project is associated with WWDC25 session 259:","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https://developer.apple.com/wwdc25/259/","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}]},{"anchor":"Configure-the-sample-code-project","text":"Configure the sample code project","level":2,"type":"heading"},{"inlineContent":[{"text":"To run this sample, you’ll need to:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Set the developer team in Xcode for the app target so it automatically manages the provisioning profile. For more information, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"https://developer.apple.com/documentation/xcode/preparing-your-app-for-distribution#Set-the-bundle-ID"},{"text":" and ","type":"text"},{"type":"reference","identifier":"https://developer.apple.com/documentation/xcode/preparing-your-app-for-distribution#Assign-the-project-to-a-team","isActive":true},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"In the Developer portal, enable the WeatherKit app service for your bundle ID so the app can access location-based weather information.","type":"text"}]}]}],"type":"orderedList"},{"level":2,"type":"heading","text":"Check model availability","anchor":"Check-model-availability"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Before using the on-device model in the app, check that the model is available by creating an instance of "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel"},{"type":"text","text":" with the "},{"isActive":true,"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/default"},{"type":"text","text":" property:"}]},{"syntax":"swift","type":"codeListing","code":["let landmark: Landmark","private let model = SystemLanguageModel.default","","var body: some View {","    switch model.availability {","    case .available:","        LandmarkTripView(landmark: landmark)","    case .unavailable(.appleIntelligenceNotEnabled):","        MessageView(","            landmark: self.landmark,","            message: \"\"\"","                     Trip Planner is unavailable because \\","                     Apple Intelligence hasn't been turned on.","                     \"\"\"","        )","    case .unavailable(.modelNotReady):","        MessageView(","            landmark: self.landmark,","            message: \"Trip Planner isn't ready yet. Try again later.\"","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app handles two unavailability scenarios: Apple Intelligence isn’t enabled or the model isn’t ready for usage. If Apple Intelligence is off, the app tells the person they need to turn it on and if the model isn’t ready, it tells the person the Trip Planner isn’t ready and to try the app again later."}]},{"content":[{"inlineContent":[{"type":"text","text":"To use the on-device language model, people need to turn on"},{"text":" ","type":"text"},{"type":"text","text":"Apple Intelligence on their device. For a list of supported"},{"text":" ","type":"text"},{"type":"text","text":"devices, see "},{"type":"reference","isActive":true,"identifier":"https://www.apple.com/apple-intelligence/"},{"type":"text","text":"."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"anchor":"Define-structured-data-for-generation","text":"Define structured data for generation","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The app starts by defining data structures with specific constraints to control what the model generates."},{"type":"text","text":" "},{"text":"The ","type":"text"},{"code":"Itinerary","type":"codeVoice"},{"text":" type uses the ","type":"text"},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable","isActive":true},{"text":" macro to create structured content that includes travel plans with activities, hotels, and restaurants.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"@Generable"},{"type":"text","text":" macro automatically converts Swift types into schemas that the model uses for constrained sampling, so you can specify guides to control the values you associate with it."},{"type":"text","text":" "},{"text":"For example, the app uses ","type":"text"},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Guide(description:)","isActive":true},{"type":"text","text":" to make sure the model creates an exciting name for the trip."},{"type":"text","text":" "},{"type":"text","text":"It also uses "},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/GenerationGuide/anyOf(_:)","isActive":true},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/GenerationGuide/count(_:)"},{"type":"text","text":" to choose any destination from our "},{"code":"ModelData","type":"codeVoice"},{"text":" and show exactly 3 ","type":"text"},{"code":"DayPlan","type":"codeVoice"},{"type":"text","text":" objects per destination, respectively."}],"type":"paragraph"},{"type":"codeListing","code":["@Generable","struct Itinerary: Equatable {","    @Guide(description: \"An exciting name for the trip.\")","    let title: String","    @Guide(.anyOf(ModelData.landmarkNames))","    let destinationName: String","    let description: String","    @Guide(description: \"An explanation of how the itinerary meets the person's special requests.\")","    let rationale: String","","    @Guide(description: \"A list of day-by-day plans.\")","    @Guide(.count(3))","    let days: [DayPlan]","}","","@Generable","struct DayPlan: Equatable {","    @Guide(description: \"A unique and exciting title for this day plan.\")","    let title: String","    let subtitle: String","    let destination: String","","    @Guide(.count(3))","    let activities: [Activity]","}","","@Generable","struct Activity: Equatable {","    let type: Kind","    let title: String","    let description: String","}","","@Generable","enum Kind {","    case sightseeing","    case foodAndDining","    case shopping","    case hotelAndLodging","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"@Generable"},{"type":"text","text":" macro automatically creates two versions of each type: the complete structure and a "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable/PartiallyGenerated","isActive":true,"type":"reference"},{"text":" version which is a mirror of the outer structure except every property is optional.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The app uses this "},{"type":"codeVoice","code":"PartiallyGenerated"},{"text":" version when streaming and displaying the itinerary generation.","type":"text"}]},{"type":"heading","anchor":"Configure-the-model-session","level":2,"text":"Configure the model session"},{"type":"paragraph","inlineContent":[{"type":"text","text":"After checking that the model is available, the app configures a "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession","isActive":true,"type":"reference"},{"text":" object with custom tools and detailed instructions in ","type":"text"},{"code":"ItineraryPlanner","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Given a location, the initializer creates the session with structured guidance for generating personalized trip recommendations."}]},{"type":"codeListing","code":["init(landmark: Landmark) {","    self.landmark = landmark","    Logging.general.log(\"The landmark is... \\(landmark.name)\")","    let pointOfInterestTool = FindPointsOfInterestTool(landmark: landmark)","    self.session = LanguageModelSession(","        tools: [pointOfInterestTool],","        instructions: Instructions {","            \"Your job is to create an itinerary for the person.\"","            ","            \"Each day needs an activity, hotel and restaurant.\"","            ","            \"\"\"","            Always use the findPointsOfInterest tool to find businesses \\","            and activities in \\(landmark.name), especially hotels \\","            and restaurants.","            ","            The point of interest categories may include:","            \"\"\"","            FindPointsOfInterestTool.categories","            ","            \"\"\"","            Here is a description of \\(landmark.name) for your reference \\","            when considering what activities to generate:","            \"\"\"","            landmark.description","        }","    )","    self.pointOfInterestTool = pointOfInterestTool","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In a generated itinerary, the model instructions ensure that each day contains an activity, hotel, and restaurant. To get the location-specific"},{"type":"text","text":" "},{"type":"text","text":"businesses and activities, the sample uses a custom tool, called "},{"type":"codeVoice","code":"FindPointsOfInterestTool"},{"text":", with the chosen landmark. The instructions also call the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"landmark description property as added context when generating the activities."}]},{"type":"heading","text":"Create a custom tool","anchor":"Create-a-custom-tool","level":2},{"inlineContent":[{"type":"text","text":"You can use custom tools to extend the functionality of a model."},{"type":"text","text":" "},{"type":"text","text":"Tool-calling allows the model to interact with external code you create to fetch up-to-date information, ground responses in sources of truth that you provide, and perform side effects."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The model in this app uses the "},{"code":"FindPointsOfInterestTool","type":"codeVoice"},{"type":"text","text":" tool to enable dynamic discovery of specific businesses and activities for the chosen landmark. The tool uses the "},{"code":"@Generable","type":"codeVoice"},{"text":" macro to make its categories and arguments available to the model.","type":"text"}]},{"code":["@Observable","final class FindPointsOfInterestTool: Tool {","    let name = \"findPointsOfInterest\"","    let description = \"Finds points of interest for a landmark.\"","    ","    let landmark: Landmark","    ","    @MainActor var lookupHistory: [Lookup] = []","    ","    init(landmark: Landmark) {","        self.landmark = landmark","    }","","@Generable","enum Category: String, CaseIterable {","    case campground","    case hotel","    case cafe","    case museum","    case marina","    case restaurant","    case nationalMonument","}","","@Generable","struct Arguments {","    @Guide(description: \"This is the type of destination to look up for.\")","    let pointOfInterest: Category","","    @Guide(description: \"The natural language query of what to search for.\")","    let naturalLanguageQuery: String","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"When you prompt the model with a question or make a request, the model decides whether it can provide an answer or if it needs the help of a tool.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The app explicitly instructs the model to always use the "},{"code":"findPointsOfInterestTool","type":"codeVoice"},{"type":"text","text":" in the "},{"type":"codeVoice","code":"ItineraryPlanner"},{"text":" instructions. This allows the model to automatically call the tool to find relevant hotels, restaurants, and activities for the destinations.","type":"text"}]},{"level":2,"anchor":"Stream-and-display-partial-responses-in-real-time","type":"heading","text":"Stream and display partial responses in real time"},{"type":"paragraph","inlineContent":[{"text":"The app shows real-time content generation by streaming partial responses from the model. The ","type":"text"},{"code":"ItineraryPlanner","type":"codeVoice"},{"type":"text","text":" uses "},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/streamResponse(generating:includeSchemaInPrompt:options:prompt:)","isActive":true},{"type":"text","text":" to generate "},{"type":"codeVoice","code":"Itinerary.PartiallyGenerated"},{"type":"text","text":" objects so itinerary items are shown incrementally to the person."}]},{"type":"paragraph","inlineContent":[{"text":"You can opt for specific ","type":"text"},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/GenerationOptions","isActive":true},{"type":"text","text":" to adjust the way the model generates these responses."},{"type":"text","text":" "},{"type":"text","text":"For generating the itinerary, the app opts for a "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/GenerationOptions/SamplingMode/greedy","type":"reference","isActive":true},{"type":"text","text":" sampling mode so the model always results in the same output for a given input."},{"type":"text","text":" "},{"type":"text","text":"This ensures the prompt generates consistent recommendations for an itinerary specific to the given landmark."}]},{"code":["private(set) var itinerary: Itinerary.PartiallyGenerated?","","func suggestItinerary(dayCount: Int) async throws {","    let stream = session.streamResponse(","        generating: Itinerary.self,","        includeSchemaInPrompt: false,","        options: GenerationOptions(sampling: .greedy)","    ) {","        \"Generate a \\(dayCount)-day itinerary to \\(landmark.name).\"","","        \"Give it a fun title and description.\"","","        \"Here is an example, but don't copy it:\"","        Itinerary.exampleTripToJapan","    }","","    for try await partialResponse in stream {","        itinerary = partialResponse.content","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The app presents the responses in a SwiftUI view."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"ItineraryPlanningView"},{"type":"text","text":" displays real-time visual feedback as the model searches for points of interest, showing people what’s happening when generating content:"}],"type":"paragraph"},{"type":"codeListing","code":["ForEach(planner.pointOfInterestTool.lookupHistory) { element in","    HStack {","        Image(systemName: \"location.magnifyingglass\")","        Text(\"Searching **\\(element.history.pointOfInterest.rawValue)** in \\(landmark.name)...\")","    }","    .transition(.blurReplace)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app displays messages like “Searching "},{"type":"strong","inlineContent":[{"text":"hotel","type":"text"}]},{"type":"text","text":" in Yosemite…” and “Searching "},{"inlineContent":[{"type":"text","text":"restaurant"}],"type":"strong"},{"text":" in Yosemite…” to let people know which point of interest category the model provided as input to the tool when actively searching for nearby points of interest.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"In the background, however, the tool executes and provides updates to the view."},{"text":" ","type":"text"},{"text":"The view shows a blurred overlay while generating each day plan, then reveals the full itinerary after the search completes.","type":"text"}]},{"anchor":"Tag-content-dynamically","text":"Tag content dynamically","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The app uses content tagging on the provided landmarks to help people quickly understand"},{"text":" ","type":"text"},{"type":"text","text":"the characteristics of each destination."},{"type":"text","text":" "},{"text":"A content tagging model produces a list of categorizing tags based on the input text you provide.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"When you prompt the content tagging model, it produces a tag that uses one to a few lowercase words."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"LandmarkDescriptionView"},{"type":"text","text":" prompts the content tagging model to automatically generate relevant hashtags for landmark descriptions, like "},{"type":"codeVoice","code":"#nature"},{"type":"text","text":", "},{"type":"codeVoice","code":"#hiking"},{"type":"text","text":", or "},{"type":"codeVoice","code":"#scenic"},{"text":", based on each landmark’s description.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For more information on initializing content tagging, see "},{"type":"reference","identifier":"doc://com.apple.documentation/documentation/FoundationModels/categorizing-and-organizing-data-with-content-tags","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let contentTaggingModel = SystemLanguageModel(useCase: .contentTagging)","",".task {","    if !contentTaggingModel.isAvailable { return }","    do {","        let session = LanguageModelSession(model: contentTaggingModel)","        let stream = session.streamResponse(","            to: landmark.description,","            generating: TaggingResponse.self,","            options: GenerationOptions(sampling: .greedy)","        )","        for try await newTags in stream {","            generatedTags = newTags.content","        }","    } catch {","        Logging.general.error(\"\\(error.localizedDescription)\")","    }","}"]},{"text":"Integrate with other framework features","type":"heading","level":2,"anchor":"Integrate-with-other-framework-features"},{"inlineContent":[{"type":"text","text":"You can combine these generative model features with other Apple frameworks. For example, the "},{"type":"codeVoice","code":"LocationLookup"},{"type":"text","text":" class uses "},{"isActive":true,"type":"reference","identifier":"doc://com.apple.documentation/documentation/MapKit"},{"text":" to search for addresses for our points of interest, showing how to combine model-generated content with weather information and location data for complete travel planning.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Observable @MainActor","final class LocationLookup {","    private(set) var item: MKMapItem?","    private(set) var temperatureString: String?","","    func performLookup(location: String) {","        Task {","            let item = await self.mapItem(atLocation: location)","            if let location = item?.location {","                self.temperatureString = await self.weather(atLocation: location)","            }","        }","    }","    ","    private func mapItem(atLocation location: String) async -> MKMapItem? {","        let request = MKLocalSearch.Request()","        request.naturalLanguageQuery = location","        ","        let search = MKLocalSearch(request: request)","        do {","            return try await search.start().mapItems.first","        } catch {","            Logging.general.error(\"Failed to look up location: \\(location). Error: \\(error)\")","        }","        return nil","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The model generates location names as text, and the ","type":"text"},{"type":"codeVoice","code":"LocationLookup"},{"text":" class converts them into real, mappable locations using the natural language search capabilities in MapKit.","type":"text"}]}]}],"sampleCodeDownload":{"kind":"sampleDownload","action":{"isActive":true,"type":"reference","overridingTitle":"Download","identifier":"5414fd17db13/AddingIntelligentAppFeaturesWithGenerativeModels.zip"}},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/foundationmodels/adding-intelligent-app-features-with-generative-models"]},{"paths":["/documentation/foundationmodels/adding-intelligent-app-features-with-generative-models"],"traits":[{"interfaceLanguage":"occ"}]}],"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.foundationmodels/documentation/FoundationModels"]]},"kind":"article","sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc://com.apple.foundationmodels/documentation/FoundationModels/adding-intelligent-app-features-with-generative-models","interfaceLanguage":"swift"},"metadata":{"platforms":[{"name":"iOS","introducedAt":"26.0","beta":false},{"introducedAt":"26.0","name":"iPadOS","beta":false},{"introducedAt":"26.0","beta":false,"name":"Mac Catalyst"},{"beta":false,"introducedAt":"26.0","name":"macOS"},{"name":"visionOS","introducedAt":"26.0","beta":false},{"introducedAt":"26.0","beta":false,"name":"Xcode"}],"title":"Adding intelligent app features with generative models","images":[{"identifier":"adding-intelligent-app-features-with-generative-models-PageImage-card.png","type":"card"}],"role":"sampleCode","roleHeading":"Sample Code","modules":[{"name":"Foundation Models"}]},"references":{"adding-intelligent-app-features-with-generative-models-PageImage-card.png":{"type":"image","identifier":"adding-intelligent-app-features-with-generative-models-PageImage-card.png","alt":null,"variants":[{"url":"https://docs-assets.developer.apple.com/published/29399e54b8f238bef3b51af88ed97253/adding-intelligent-app-features-with-generative-models-PageImage-card%402x.png","traits":["2x","light"]},{"url":"https://docs-assets.developer.apple.com/published/5b6f36cef31dcb9443d08d1885d21cab/adding-intelligent-app-features-with-generative-models-PageImage-card~dark%402x.png","traits":["2x","dark"]}]},"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/default":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"`default`","kind":"identifier"},{"kind":"text","text":": "},{"text":"SystemLanguageModel","preciseIdentifier":"s:16FoundationModels19SystemLanguageModelC","kind":"typeIdentifier"}],"kind":"symbol","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/default","abstract":[{"text":"The base version of the model.","type":"text"}],"title":"default","role":"symbol","type":"topic","url":"/documentation/foundationmodels/systemlanguagemodel/default"},"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel":{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel","title":"SystemLanguageModel","abstract":[{"text":"An on-device large language model capable of text generation tasks.","type":"text"}],"type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SystemLanguageModel"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SystemLanguageModel"}],"url":"/documentation/foundationmodels/systemlanguagemodel"},"https://developer.apple.com/wwdc25/259/":{"titleInlineContent":[{"type":"text","text":"Code-along: Add Intelligence to your App using the Foundation Models framework"}],"type":"link","url":"https://developer.apple.com/wwdc25/259/","identifier":"https://developer.apple.com/wwdc25/259/","title":"Code-along: Add Intelligence to your App using the Foundation Models framework"},"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable/PartiallyGenerated":{"role":"symbol","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PartiallyGenerated","kind":"identifier"},{"kind":"text","text":" : "},{"text":"ConvertibleFromGeneratedContent","preciseIdentifier":"s:16FoundationModels31ConvertibleFromGeneratedContentP","kind":"typeIdentifier"},{"kind":"text","text":" = "},{"text":"Self","kind":"typeIdentifier"}],"type":"topic","abstract":[{"type":"text","text":"A representation of partially generated content"}],"kind":"symbol","title":"PartiallyGenerated","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable/PartiallyGenerated","required":true,"defaultImplementations":1,"url":"/documentation/foundationmodels/generable/partiallygenerated"},"https://www.apple.com/apple-intelligence/":{"title":"Apple Intelligence","type":"link","identifier":"https://www.apple.com/apple-intelligence/","titleInlineContent":[{"text":"Apple Intelligence","type":"text"}],"url":"https://www.apple.com/apple-intelligence/"},"foundation-models-PageImage-card.png":{"type":"image","identifier":"foundation-models-PageImage-card.png","alt":"An abstract illustration with lines coming together to form a single line.","variants":[{"url":"https://docs-assets.developer.apple.com/published/096a5d179ca102a325db9f643e9bc31e/foundation-models-PageImage-card.png","traits":["1x","light"]},{"url":"https://docs-assets.developer.apple.com/published/bd8f99c52038bd092000c924ab2ded3b/foundation-models-PageImage-card~dark.png","traits":["1x","dark"]}]},"https://developer.apple.com/documentation/xcode/preparing-your-app-for-distribution#Assign-the-project-to-a-team":{"titleInlineContent":[{"type":"text","text":"Assign the project to a team"}],"type":"link","url":"https://developer.apple.com/documentation/xcode/preparing-your-app-for-distribution#Assign-the-project-to-a-team","identifier":"https://developer.apple.com/documentation/xcode/preparing-your-app-for-distribution#Assign-the-project-to-a-team","title":"Assign the project to a team"},"doc://com.apple.foundationmodels/documentation/FoundationModels/generating-content-and-performing-tasks-with-foundation-models":{"title":"Generating content and performing tasks with Foundation Models","type":"topic","url":"/documentation/foundationmodels/generati