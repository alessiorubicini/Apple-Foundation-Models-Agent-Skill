{"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.foundationmodels/documentation/FoundationModels"]]},"metadata":{"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Tool"}],"symbolKind":"protocol","platforms":[{"beta":false,"name":"iOS","introducedAt":"26.0","unavailable":false,"deprecated":false},{"introducedAt":"26.0","deprecated":false,"beta":false,"unavailable":false,"name":"iPadOS"},{"unavailable":false,"introducedAt":"26.0","name":"Mac Catalyst","deprecated":false,"beta":false},{"deprecated":false,"unavailable":false,"name":"macOS","introducedAt":"26.0","beta":false},{"introducedAt":"26.0","beta":false,"name":"visionOS","unavailable":false,"deprecated":false}],"modules":[{"name":"Foundation Models"}],"navigatorTitle":[{"kind":"identifier","text":"Tool"}],"title":"Tool","role":"symbol","roleHeading":"Protocol","externalID":"s:16FoundationModels4ToolP"},"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","title":"Inherits From","identifiers":["doc://com.externally.resolved.symbol/s:s8SendableP","doc://com.externally.resolved.symbol/s:s16SendableMetatypeP"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Tool"},{"kind":"text","text":"<"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/Arguments","kind":"typeIdentifier","text":"Arguments","preciseIdentifier":"s:16FoundationModels4ToolP9ArgumentsQa"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Output","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/Output","preciseIdentifier":"s:16FoundationModels4ToolP6OutputQa"},{"kind":"text","text":"> : "},{"identifier":"doc://com.externally.resolved.symbol/s:s8SendableP","text":"Sendable","kind":"typeIdentifier","preciseIdentifier":"s:s8SendableP"}],"languages":["swift"],"platforms":["iOS","iPadOS","Mac Catalyst","macOS","visionOS"]}]},{"kind":"mentions","mentions":["doc://com.apple.foundationmodels/documentation/FoundationModels/generating-content-and-performing-tasks-with-foundation-models","doc://com.apple.foundationmodels/documentation/FoundationModels/categorizing-and-organizing-data-with-content-tags","doc://com.apple.foundationmodels/documentation/FoundationModels/expanding-generation-with-tool-calling"]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Tool calling gives the model the ability to call your code to incorporate","type":"text"},{"text":" ","type":"text"},{"text":"up-to-date information like recent events and data from your app. A tool","type":"text"},{"type":"text","text":" "},{"type":"text","text":"includes a name and a description that the framework puts in the prompt to let"},{"text":" ","type":"text"},{"text":"the model decide when and how often to call your tool.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":"Tool","type":"codeVoice"},{"type":"text","text":" defines a "},{"isActive":true,"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/call(arguments:)"},{"type":"text","text":" method that takes arguments that conforms to"},{"type":"text","text":" "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/ConvertibleFromGeneratedContent","type":"reference","isActive":true},{"type":"text","text":", and returns an output of any type that conforms to"},{"type":"text","text":" "},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/PromptRepresentable","isActive":true},{"text":", allowing the model to understand and reason about in subsequent","type":"text"},{"type":"text","text":" "},{"type":"text","text":"interactions. Typically, "},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/Output","isActive":true},{"type":"text","text":" is a "},{"code":"String","type":"codeVoice"},{"type":"text","text":" or any "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable","isActive":true,"type":"reference"},{"type":"text","text":" types."}]},{"code":["struct FindContacts: Tool {","    let name = \"findContacts\"","    let description = \"Find a specific number of contacts\"","","    @Generable","    struct Arguments {","        @Guide(description: \"The number of contacts to get\", .range(1...10))","        let count: Int","    }","","    func call(arguments: Arguments) async throws -> [String] {","        var contacts: [CNContact] = []","        // Fetch a number of contacts using the arguments.","        let formattedContacts = contacts.map {","            \"\\($0.givenName) \\($0.familyName)\"","        }","        return formattedContacts","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Tools must conform to "},{"type":"reference","identifier":"doc://com.apple.documentation/documentation/Swift/Sendable","isActive":true},{"type":"text","text":" "},{"text":"so the framework can run them concurrently. If the model needs to pass the output","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of one tool as the input to another, it executes back-to-back tool calls."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You control the life cycle of your tool, so you can track the state of it between"},{"text":" ","type":"text"},{"text":"calls to the model. For example, you might store a list of database records that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you don’t want to reuse between tool calls."}]},{"type":"paragraph","inlineContent":[{"text":"Prompting the model with tools contributes to the available context window size.","type":"text"},{"text":" ","type":"text"},{"text":"When you provide a tool in your generation request, the framework puts the tool","type":"text"},{"text":" ","type":"text"},{"text":"definitions — name, description, parameter information — in the prompt so the","type":"text"},{"text":" ","type":"text"},{"text":"model can decide when and how often to call the tool. After calling your tool,","type":"text"},{"text":" ","type":"text"},{"text":"the framework returns the tool’s output back to the model for further processing.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To efficiently use tool calling:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reduce "},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Guide(description:)","isActive":true},{"type":"text","text":" descriptions to a short phrase each."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Limit the number of tools you use to three to five."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Include a tool only when its necessary for the task you want to perform."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Run an essential tool before calling the model and integrate the tool’s output"},{"type":"text","text":" "},{"type":"text","text":"in the prompt directly."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"If your session exceeds the available context size, it throws","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/GenerationError/exceededContextWindowSize(_:)","type":"reference"},{"text":". When","type":"text"},{"text":" ","type":"text"},{"text":"you encounter the context window limit, consider breaking up tool calls across","type":"text"},{"type":"text","text":" "},{"text":"new ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession","isActive":true,"type":"reference"},{"text":" instances. For more information on managing the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"context window size, see"},{"text":" ","type":"text"},{"identifier":"doc://com.apple.documentation/documentation/Technotes/tn3193-managing-the-on-device-foundation-model-s-context-window","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/foundationmodels/tool"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"topicSections":[{"identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/call(arguments:)","doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/Arguments","doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/Output"],"anchor":"Invoking-a-tool","title":"Invoking a tool"},{"identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/description","doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/includesSchemaInInstructions","doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/name","doc://com.apple.foundationmodels/documentation/FoundationModels/Tool/parameters"],"anchor":"Getting-the-tool-properties","title":"Getting the tool properties"}],"seeAlsoSections":[{"generated":true,"anchor":"Tool-calling","title":"Tool calling","identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/expanding-generation-with-tool-calling","doc://com.apple.foundationmodels/documentation/FoundationModels/generate-dynamic-game-content-with-guided-generation-and-tools"]}],"identifier":{"url":"doc://com.apple.foundationmodels/documentation/FoundationModels/Tool","interfaceLanguage":"swift"},"abstract":[{"text":"A