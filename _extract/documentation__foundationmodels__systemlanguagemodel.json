,"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.foundationmodels/documentation/FoundationModels"]]},"identifier":{"url":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"SystemLanguageModel","kind":"identifier"}],"platforms":["iOS","iPadOS","Mac Catalyst","macOS","visionOS"]}]},{"mentions":["doc://com.apple.foundationmodels/documentation/FoundationModels/improving-the-safety-of-generative-model-output","doc://com.apple.foundationmodels/documentation/FoundationModels/generating-content-and-performing-tasks-with-foundation-models","doc://com.apple.foundationmodels/documentation/FoundationModels/loading-and-using-a-custom-adapter-with-foundation-models"],"kind":"mentions"},{"content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"SystemLanguageModel","type":"codeVoice"},{"type":"text","text":" refers to the on-device text foundation model that powers Apple"},{"text":" ","type":"text"},{"type":"text","text":"Intelligence. Use "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/default"},{"type":"text","text":" to access the base version of the model and perform general-purpose"},{"type":"text","text":" "},{"type":"text","text":"text generation tasks. To access a specialized version of the model, initialize the model"},{"type":"text","text":" "},{"type":"text","text":"with "},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/UseCase","isActive":true},{"type":"text","text":" to perform tasks like "},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/UseCase/contentTagging","type":"reference","isActive":true},{"type":"text","text":". Apple will periodically"},{"type":"text","text":" "},{"type":"text","text":"update "},{"code":"SystemLanguageModel","type":"codeVoice"},{"type":"text","text":" in routine OS updates to improve the on-device model’s abilities and"},{"type":"text","text":" "},{"text":"performance. Currently there are 2 model versions that align with:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"iOS, iPadOS, macOS, and visionOS "},{"inlineContent":[{"type":"text","text":"26.0 - 26.3"}],"type":"strong"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS, macOS, visionOS ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"26.4"}]}]}]}]},{"type":"paragraph","inlineContent":[{"text":"To better understand the impact of model version on your app, see the guide ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/updating-prompts-for-new-model-versions","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Before you use the model, you’ll need to verify its availability. Model availability depends on device factors like:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The device must support Apple Intelligence."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple Intelligence must be turned on in Settings."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/Availability-swift.enum"},{"type":"text","text":" to change what your app shows to people based on the availability condition:"}]},{"type":"codeListing","syntax":"swift","code":["struct GenerativeView: View {","    // Create a reference to the system language model.","    private var model = SystemLanguageModel.default","","    var body: some View {","        switch model.availability {","        case .available:","            // Show your intelligence UI.","        case .unavailable(.deviceNotEligible):","            // Show an alternative UI.","        case .unavailable(.appleIntelligenceNotEnabled):","            // Ask the person to turn on Apple Intelligence.","        case .unavailable(.modelNotReady):","            // The model isn't ready because it's downloading or because","            // of other system reasons.","        case .unavailable(let other):","            // The model is unavailable for an unknown reason.","        }","    }","}"]}],"kind":"content"}],"seeAlsoSections":[{"title":"Essentials","identifiers":["doc://com.apple.documentation/documentation/Updates/FoundationModels","doc://com.apple.foundationmodels/documentation/FoundationModels/generating-content-and-performing-tasks-with-foundation-models","doc://com.apple.foundationmodels/documentation/FoundationModels/adding-intelligent-app-features-with-generative-models"],"anchor":"Essentials","generated":true}],"references":{"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/supportsLocale(_:)":{"title":"supportsLocale(_:)","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/supportsLocale(_:)","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"supportsLocale","kind":"identifier"},{"kind":"text","text":"("},{"text":"Locale","preciseIdentifier":"s:10Foundation6LocaleV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"url":"/documentation/foundat