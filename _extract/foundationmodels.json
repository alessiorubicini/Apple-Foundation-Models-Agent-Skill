onModels/Prompt","doc://com.apple.foundationmodels/documentation/FoundationModels/Transcript","doc://com.apple.foundationmodels/documentation/FoundationModels/GenerationOptions"],"anchor":"Prompting"},{"identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/generating-swift-data-structures-with-guided-generation","doc://com.apple.foundationmodels/documentation/FoundationModels/Generable"],"anchor":"Guided-generation","title":"Guided generation"},{"title":"Tool calling","anchor":"Tool-calling","identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/expanding-generation-with-tool-calling","doc://com.apple.foundationmodels/documentation/FoundationModels/generate-dynamic-game-content-with-guided-generation-and-tools","doc://com.apple.foundationmodels/documentation/FoundationModels/Tool"]},{"anchor":"Safety","identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/improving-the-safety-of-generative-model-output","doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/Guardrails"],"title":"Safety"},{"identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/supporting-languages-and-locales-with-foundation-models","doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/supportsLocale(_:)","doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/GenerationError/unsupportedLanguageOrLocale(_:)"],"anchor":"Language-and-locales","title":"Language and locales"},{"title":"Use cases","anchor":"Use-cases","identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/categorizing-and-organizing-data-with-content-tags","doc://com.apple.foundationmodels/documentation/FoundationModels/SystemLanguageModel/UseCase"]},{"title":"Feedback","anchor":"Feedback","identifiers":["doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelFeedback","doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/logFeedbackAttachment(sentiment:issues:desiredOutput:)"]}],"abstract":[{"text":"Perform tasks with the on-device model that specializes in language understanding, structured output, and tool calling.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["/documentation/foundationmodels"]}],"sections":[],"primaryContentSections":[{"kind":"mentions","mentions":["doc://com.apple.foundationmodels/documentation/FoundationModels/updating-prompts-for-new-model-versions"]},{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The Foundation Models framework provides access to Apple’s on-device large language"},{"type":"text","text":" "},{"text":"model that powers Apple Intelligence to help you perform intelligent tasks specific","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to your use case. The text-based on-device model identifies patterns that"},{"type":"text","text":" "},{"type":"text","text":"allow for generating new text that’s appropriate for the request you make, and it"},{"text":" ","type":"text"},{"type":"text","text":"can make decisions to call code you write to perform specialized tasks."}],"type":"paragraph"},{"inlineContent":[{"identifier":"foundation-models-framework-hero","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Generate text content based on requests you make. The on-device model excels at"},{"type":"text","text":" "},{"type":"text","text":"a diverse range of text generation tasks, like summarization, entity extraction,"},{"text":" ","type":"text"},{"type":"text","text":"text understanding, refinement, dialog for games, generating creative content,"},{"text":" ","type":"text"},{"type":"text","text":"and more."}],"type":"paragraph"},{"inlineContent":[{"text":"Generate entire Swift data structures with guided generation. With the ","type":"text"},{"code":"@Generable","type":"codeVoice"},{"type":"text","text":" macro,"},{"type":"text","text":" "},{"type":"text","text":"you can define custom data structures and the framework provides strong guarantees"},{"type":"text","text":" "},{"type":"text","text":"that the model generates instances of your type."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To expand what the on-device foundation model can do, use "},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Tool","isActive":true},{"type":"text","text":" to create custom"},{"type":"text","text":" "},{"text":"tools that the model can call to assist with handling your request. For example,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the model can call a tool that searches a local or online database for information,"},{"type":"text","text":" "},{"text":"or calls a service in your app.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use the on-device language model, people need to turn on Apple Intelligence on"},{"text":" ","type":"text"},{"text":"their device. For a list of supported devices, see ","type":"text"},{"type":"reference","identifier":"https://www.apple.com/apple-intelligence/","isActive":true},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"For more information about acceptable usage of the Foundation Models framework,"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"isActive":true,"type":"reference","identifier":"https://developer.apple.com/apple-intelligence/acceptable-use-requirements-for-the-foundation-models-framework"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Related-videos","type":"heading","text":"Related videos","level":3},{"style":"compactGrid","items":["doc://com.apple.documentation/videos/play/wwdc2025/286","doc://com.apple.documentation/videos/play/wwdc2025/301","doc://com.apple.documentation/videos/play/wwdc2025/259"],"t