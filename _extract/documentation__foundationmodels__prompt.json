:false,"unavailable":false,"introducedAt":"26.0","beta":false,"name":"Mac Catalyst"},{"beta":false,"introducedAt":"26.0","deprecated":false,"unavailable":false,"name":"macOS"},{"introducedAt":"26.0","unavailable":false,"deprecated":false,"beta":false,"name":"visionOS"}],"role":"symbol","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"Prompt","kind":"identifier"}],"navigatorTitle":[{"text":"Prompt","kind":"identifier"}],"title":"Prompt","externalID":"s:16FoundationModels6PromptV"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc://com.externally.resolved.symbol/s:s8CopyableP","doc://com.externally.resolved.symbol/s:s9EscapableP","doc://com.apple.foundationmodels/documentation/FoundationModels/PromptRepresentable","doc://com.externally.resolved.symbol/s:s8SendableP","doc://com.externally.resolved.symbol/s:s16SendableMetatypeP"],"type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Prompt"}],"platforms":["iOS","iPadOS","Mac Catalyst","macOS","visionOS"],"languages":["swift"]}],"kind":"declarations"},{"mentions":["doc://com.apple.foundationmodels/documentation/FoundationModels/generating-content-and-performing-tasks-with-foundation-models","doc://com.apple.foundationmodels/documentation/FoundationModels/prompting-an-on-device-foundation-model"],"kind":"mentions"},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prompts can contain content written by you, an outside source, or input"},{"type":"text","text":" "},{"type":"text","text":"directly from people using your app. You can initialize a "},{"code":"Prompt","type":"codeVoice"},{"type":"text","text":" from a string"},{"type":"text","text":" "},{"type":"text","text":"literal:"}]},{"type":"codeListing","code":["let prompt = Prompt(\"What are miniature schnauzers known for?\")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/PromptBuilder","isActive":true,"type":"reference"},{"text":" to dynamically control the prompt’s content based on your","type":"text"},{"type":"text","text":" "},{"text":"app’s state. The code below shows that if the Boolean is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":", the prompt","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"includes a second line of text:"}]},{"syntax":"swift","code":["let responseShouldRhyme = true","let prompt = Prompt {","    \"Answer the following question from the user: \\(userInput)\"","    if responseShouldRhyme {","        \"Your response MUST rhyme!\"","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"If your prompt includes input from people, consider wrapping the input in a string","type":"text"},{"text":" ","type":"text"},{"text":"template with your own prompt to better steer the model’s response. For more","type":"text"},{"text":" ","type":"text"},{"text":"information on handling inputs in your prompts, see ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/improving-the-safety-of-generative-model-output","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"All input to the model contributes tokens to the context window of the","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession"},{"text":" — including the ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Instructions","type":"reference","isActive":true},{"text":", ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Prompt","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Tool","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and "},{"type":"reference","isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/Generable"},{"type":"text","text":" types, and the model’s responses. If your session exceeds the"},{"text":" ","type":"text"},{"type":"text","text":"available context size, it throws"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession/GenerationError/exceededContextWindowSize(_:)"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Prompts can consume a lot of tokens, especially when you send multiple prompts to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"same session. To reduce your prompt size when you exceed the context window size:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Write shorter prompts to save tokens.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Provide only the information necessary to perform the task."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Use concise and imperative language instead of indirect or jargon that the model"},{"type":"text","text":" "},{"type":"text","text":"might misinterpret."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a clear verb that tells the model what to do, like “Generate”, “List”, or “Summarize”."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Include the target response length you want, like “In three sentences” or “List five reasons”.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prompting the same session eventually leads to exceeding the context window size."},{"type":"text","text":" "},{"type":"text","text":"When that happens, create a new context window by initializing a new instance of"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc://com.apple.foundationmodels/documentation/FoundationModels/LanguageModelSession","isActive":true},{"text":". For more information on managing the context window size, see","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc://com.apple.documentation/documentation/Technotes/tn3193-managing-the-on-device-foundation-model-s-context-window"},{"type":"text","text":"."}]}]}],"references":{"doc://com.externally.resolved.symbol/s:s16SendableMetatypeP":{"type":"topic","url":"/documentation/Swift/SendableMetatype","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"SendableMetatype","kind":"identifier"}],"identifier":"doc://com.externally.resolved.symbol/s:s16SendableMetatypeP","role":"symbol","title":"SendableMetatype","kind":"symbol","abstract":[{"text":"A type whose metatype can be shared across arbitrary concurrent contexts without introducing a risk of data races.","type":"text"}]},"evaluating-your-apps-prompts-PageImage-card.png":{"variants":[{"traits":["2x","light"],"url":"https://docs-assets.developer.apple.com/published/0ad5408e2642641ece9c23cbde0aa1de/evaluating-your-apps-prompts-PageImage-card%402x.png"},{"traits":["2x","dark"],"url":"https://docs-assets.developer.apple.com/published/180c28d7d9637ef0f5e50863d735867d/evaluating-your-apps-prompts-PageImage-card~dark%402x.png"}],"alt":"An abstract illustration with a magnifying glass in the center with several ovals representing prompts being evaluated.","type":"image","identifier":"evaluating-your-apps-prompts-PageImage-card.png"},"doc